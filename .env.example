# 卷轴 (Scroll) 配置示例
# 复制此文件为 .env 并填入你的实际配置
# .env 文件已在 .gitignore 中排除，不会被提交到 Git

# ---- AI 服务配置 (OpenAI 兼容协议) ----

# 服务名称（任意，仅用于 UI 展示）
SCROLL_AI_NAME=DeepSeek

# API 地址 (OpenAI 兼容协议)
SCROLL_AI_BASE_URL=https://api.deepseek.com/v1

# API Key
SCROLL_AI_API_KEY=sk-your-api-key-here

# 模型名称
SCROLL_AI_MODEL=deepseek-chat

# 最大 Token 数
SCROLL_AI_MAX_TOKENS=4096

# ---- 可选：第二个 AI 服务（翻译专用，可选） ----
# SCROLL_AI_TRANSLATE_BASE_URL=https://api.openai.com/v1
# SCROLL_AI_TRANSLATE_API_KEY=sk-your-translate-key
# SCROLL_AI_TRANSLATE_MODEL=gpt-4o-mini
