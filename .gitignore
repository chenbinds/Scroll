# ============================================================
# 隐私 & 安全 — 绝对不要提交到 Git 的文件
# ============================================================

# 环境变量（包含 API Key、密钥等敏感信息）
.env
.env.local
.env.*.local
*.env

# 用户配置（运行时生成，可能包含 API Key）
config.json
settings.json
user-config.json
*.user.config

# 本地数据库（包含用户阅读记录、标注等隐私数据）
*.sqlite
*.sqlite3
*.db
data/

# ============================================================
# 依赖 & 构建产物
# ============================================================

node_modules/
out/
dist/
build/
release/

# electron-builder 输出
*.exe
*.msi
*.AppImage
*.dmg
*.snap

# ============================================================
# IDE & 编辑器
# ============================================================

.vscode/settings.json
.vscode/launch.json
.idea/
*.swp
*.swo
*~

# ============================================================
# 操作系统
# ============================================================

.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini

# ============================================================
# 日志 & 临时文件
# ============================================================

*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
tmp/
temp/
calibre-portable/
tools/offline/*.7z
winCodeSign*.7z

# electron-vite / 调试残留
electron.vite.config.*.mjs
scripts/boot-*.txt
scripts/test-douban*.mjs
